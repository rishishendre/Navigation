<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="frame_robot">


  <material name="grey">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>

  <xacro:macro name="lidar" params="name xyz rpy">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="0.04" length="0.03"/>
        </geometry>
        <material name="grey"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.04" length="0.03"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"
                ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="links" params="name l w h xyz rpy">
    <link name="${name}">
      <visual>
        <geometry>
          <box size="${l} ${w} ${h}"/>
        </geometry>
        <material name="grey"/>
      </visual>

      <collision>
        <geometry>
          <box size="${l} ${w} ${h}"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.01" iyy="0.01" izz="0.01"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="wheels" params="name xyz rpy">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="0.0725" length="0.048"/>
        </geometry>
        <material name="grey"/>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="0.0725" length="0.048"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.01" iyy="0.01" izz="0.01"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <gazebo reference="${name}">
        <mu1>1.0</mu1>   <!-- forward grip -->
        <mu2>0.01</mu2>  <!-- sideways slip -->
      </gazebo> 
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/> <!--done--> 
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <origin xyz="-0.175 0.175 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <link name="base_footprint"/>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0725" rpy="0 0 0"/>
      <geometry>
        <box size="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>
  <!-- links-->
  <xacro:links name="links_left"
              l="0.8" w="0.1" h="0.02"
              xyz="0 0.35 0" rpy="0 0 0"/>

  <xacro:links name="links_right"
              l="0.8" w="0.1" h="0.02"
              xyz="0 -0.35 0" rpy="0 0 0"/>

  <xacro:links name="links_middle"
              l="0.8" w="0.1" h="0.02"
              xyz="0 0 0" rpy="0 0 1.5708"/>            

  <xacro:links name="links_front"
              l="0.8" w="0.1" h="0.02"
              xyz="0.35 0 0" rpy="0 0 1.5708"/>

  <xacro:links name="links_rear"
              l="0.8" w="0.1" h="0.02"
              xyz="-0.35 0 0" rpy="0 0 1.5708"/>
  <xacro:links name="wheel_support_1"
              l="0.8" w="0.045" h="0.02"
              xyz="0 -0.127 0" rpy="0 0 0"/>
  <xacro:links name="wheel_support_2"
              l="0.8" w="0.045" h="0.02"
              xyz="0 0.127 0" rpy="0 0 0"/>
  <xacro:links name="wheel_support_3"
                l="0.8" w="0.045" h="0.02"
                xyz="0 -0.223 0" rpy="0 0 0"/>
  <xacro:links name="wheel_support_4"
                l="0.8" w="0.045" h="0.02"
                xyz="0 0.223 0" rpy="0 0 0"/>

  <!-- wheels-->
  <xacro:wheels name="wheels_fl"
              xyz="0.175 0.175 0" rpy="0 1.57 1.5708"/>
  
  <xacro:wheels name="wheels_bl"
              xyz="-0.175 0.175 0" rpy="0 1.57 1.5708"/>
  
  <xacro:wheels name="wheels_fr"
              xyz="0.175 -0.175 0" rpy="0 1.57 1.5708"/>
  
  <xacro:wheels name="wheels_br"
              xyz="-0.175 -0.175 0" rpy="0 1.57 1.5708"/>       

  <xacro:lidar name ="laser" 
              xyz="0 0 0" rpy="0 0 0"/>                 
  <!-- links joints-->

  <joint name="Base_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  
  <ros2_control name="GazeboSystem" type="system">
      <hardware>
      <!-- Gazebo → ros2_control bridge -->
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <joint name="wheels_bl_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="wheels_fl_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="wheels_fr_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="wheels_br_joint">
        <command_interface name="velocity"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
  </ros2_control>


  <gazebo>
      <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find r2_robot)/config/controllers.yaml</parameters>
      </plugin>
  </gazebo>


