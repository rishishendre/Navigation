<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="frame_robot">


  <material name="grey">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>

  <xacro:macro name="lidar" params="name xyz rpy">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.04" length="0.03"/>
        </geometry>
        <material name="grey"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.04" length="0.03"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"
                ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
  </xacro:macro>


  <xacro:macro name="links" params="name l w h xyz rpy">
    <link name="${name}">
      <visual>
        <origin xyz="${xyz}" rpy="${rpy}"/>
        <geometry>
          <box size="${l} ${w} ${h}"/>
        </geometry>
        <material name="grey"/>
      </visual>

      <collision>
        <origin xyz="${xyz}" rpy="${rpy}"/>
        <geometry>
          <box size="${l} ${w} ${h}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="1.0"/>
        <inertia ixx="0.01" iyy="0.01" izz="0.01"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:macro name="wheels" params="name xyz rpy">
    <link name="${name}">
      <visual>
        <origin xyz="${xyz}" rpy="${rpy}"/>
        <geometry>
          <cylinder radius="0.0725" length="0.048"/>
        </geometry>
        <material name="grey"/>
      </visual>

      <collision>
        <origin xyz="${xyz}" rpy="${rpy}"/>
        <geometry>
          <cylinder radius="0.0725" length="0.048"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.01" iyy="0.01" izz="0.01"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
  </xacro:macro>

  <link name="base_footprint"/>
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0725" rpy="0 0 0"/>
      <geometry>
        <box size="0 0 0"/>
      </geometry>
    </visual>
  </link>
  <!-- links-->
  <xacro:links name="links_left"
              l="0.8" w="0.1" h="0.02"
              xyz="0 0.35 0" rpy="0 0 0"/>

  <xacro:links name="links_right"
              l="0.8" w="0.1" h="0.02"
              xyz="0 -0.35 0" rpy="0 0 0"/>

  <xacro:links name="links_middle"
              l="0.8" w="0.1" h="0.02"
              xyz="0 0 0" rpy="0 0 1.5708"/>            

  <xacro:links name="links_front"
              l="0.8" w="0.1" h="0.02"
              xyz="0.35 0 0" rpy="0 0 1.5708"/>

  <xacro:links name="links_rear"
              l="0.8" w="0.1" h="0.02"
              xyz="-0.35 0 0" rpy="0 0 1.5708"/>
  <xacro:links name="wheel_support_1"
              l="0.8" w="0.045" h="0.02"
              xyz="0 -0.127 0" rpy="0 0 0"/>
  <xacro:links name="wheel_support_2"
              l="0.8" w="0.045" h="0.02"
              xyz="0 0.127 0" rpy="0 0 0"/>
  <xacro:links name="wheel_support_3"
                l="0.8" w="0.045" h="0.02"
                xyz="0 -0.223 0" rpy="0 0 0"/>
  <xacro:links name="wheel_support_4"
                l="0.8" w="0.045" h="0.02"
                xyz="0 0.223 0" rpy="0 0 0"/>

  <!-- wheels-->
  <xacro:wheels name="wheels_fl"
              xyz="0 0 0" rpy="0 1.57 1.5708"/>
  
  <xacro:wheels name="wheels_bl"
              xyz="0 0 0" rpy="0 1.57 1.5708"/>
  
  <xacro:wheels name="wheels_fr"
              xyz="0 0 0" rpy="0 1.57 1.5708"/>
  
  <xacro:wheels name="wheels_br"
              xyz="0 0 0" rpy="0 1.57 1.5708"/>       

  <xacro:lidar name ="laser" 
              xyz="0 0 0" rpy="0 0 0"/>                 
  <!-- links joints-->

  <joint name="Base_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>

  </joint>
  <joint name="left_links_joint" type="fixed">
    <parent link="base_link"/>
    <child link="links_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="right_links_joint" type="fixed">
    <parent link="base_link"/>
    <child link="links_right"/>
  </joint>
  
  <joint name="middle_links_joint" type="fixed">
    <parent link="base_link"/>
    <child link="links_middle"/>
  </joint>

  <joint name="front_links_joint" type="fixed">
    <parent link="base_link"/>
    <child link="links_front"/>
  </joint>

  <joint name="rear_links_joint" type="fixed">
    <parent link="base_link"/>
    <child link="links_rear"/>
  </joint>
  
  <!-- wheelsupport -->
  <joint name="wheel_support_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_support_1"/>
  </joint>

  <joint name="wheel_support_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_support_2"/>
  </joint>

  <joint name="wheel_support_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_support_3"/>
  </joint>

  <joint name="wheel_support_4_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_support_4"/>
  </joint>

  <joint name="wheels_bl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheels_bl"/> <!--done--> 
    <origin xyz="-0.175 0.175 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <joint name="wheels_fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheels_fl"/><!--done-->
    <origin xyz="0.175 0.175 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="wheels_br_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheels_br"/><!--done-->
    <origin xyz="-0.175 -0.175 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  
  <joint name="wheels_fr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheels_fr"/>
    <origin xyz="0.175 -0.175 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0.35 0 0.02" rpy="0 0 -1.5708"/>
  </joint>
  
  <gazebo>
    <plugin name="planar_move" filename="libgazebo_ros_diff_drive.so">

      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>

      <left_joint>wheels_fl_joint</left_joint>
      <right_joint>wheels_fr_joint</right_joint>

      
      <wheel_separation>0.35</wheel_separation>
      <wheel_diameter>0.145</wheel_diameter>

      <odometry_frame>odom</odometry_frame>
      <odometry_topic>odom</odometry_topic>
      <robot_base_frame>base_footprint</robot_base_frame>


      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <update_rate>30.0</update_rate>

    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <!-- <namespace>/tb3</namespace> -->
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>

      <joint_name>wheels_fl_joint</joint_name>
      <joint_name>wheels_fr_joint</joint_name>
      <joint_name>wheels_bl_joint</joint_name>
      <joint_name>wheels_br_joint</joint_name>
    </plugin>    
  </gazebo>
  <gazebo reference="laser">
    <sensor name="lidar" type="ray">
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1080</samples>
            <min_angle>0</min_angle>
            <max_angle>3.1457</max_angle>
          </horizontal>
        </scan>
      <range>
        <min>0.12</min>
        <max>25.0</max>
      </range>
      </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>

        <frame_name>laser</frame_name>
        <output_type>sensor_msgs/LaserScan</output_type>
      </plugin>
    </sensor>
  </gazebo>



</robot>

